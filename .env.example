# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/affirmation_app

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# AI Configuration (Groq)
OPENAI_API_KEY=gsk_your_groq_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.1-8b-instant

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
# Comma-separated list of allowed origins for web clients (e.g., frontend, companion dashboards).
# Native mobile apps, Postman, and server-to-server requests don't send an Origin header and are allowed dynamically.
# In development, local network IPs (192.168.x.x), Android emulator loopbacks (10.0.2.2), and Expo tunnels (*.exp.direct) are matched automatically.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,https://yourdomain.com

# Daily Generation Limits
FREE_TIER_DAILY_LIMIT=5
PREMIUM_TIER_DAILY_LIMIT=50